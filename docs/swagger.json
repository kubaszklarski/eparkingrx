swagger: "2.0"
info:
  description: "This is API definition for eParkingRX application"
  version: 1.0.0
  title: "eParkingRX API"
  termsOfService: "http://swagger.io/terms/"
  contact:
    email: "kuba.szklarski@gmail.com"
  license:
    name: "Apache 2.0"
    url: "http://www.apache.org/licenses/LICENSE-2.0.html"
host: "eparkingrx.swagger.io"
basePath: "/v1"
tags:
- name: "Account"
  description: "Service for account administration"
- name: "Parking"
  description: "Service for running parking operation"
- name: "Charge"
  description: "Service for calculating charging parking fees"
- name: "Rate"
  description: "Service to administer parking rates"
- name: "Payment"
  description: "Service to process payments"
paths:
  /accountsxxx:
    post:
      tags:
      - "Account"
      summary: "Register account"
      operationId: "registerAccount"
      consumes:
      - "application/json"
      produces:
      - "application/json"
      parameters: 
      - in: "body"
        name: "body"
        description: "Account object that needs to be registered"
        required: true
        schema:
          $ref: "#/definitions/Account"
      responses:
        201:
          description: "Created"
          schema:
            $ref: "#/definitions/AccountId"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"
  /accounts/{AccountId}:
    get:
      tags:
      - "Account"
      summary: "Retrieve account"
      operationId: "retrieveAccount"
      produces:
      - "application/json"
      parameters:
      - name: "AccountId"
        in: "path"
        type: "string"
        required: true
      responses:
        200:
          description: "OK"
          schema:
            $ref: "#/definitions/Account"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        404:
          description: "Not Found"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"
  /parkings:
    post:
      tags:
      - "Parking"
      summary: "Start parking"
      operationId: "startParking"
      consumes:
      - "application/json"
      produces:
      - "application/json"
      parameters: 
      - in: "body"
        name: "body"
        description: "Parking object"
        required: true
        schema:
          $ref: "#/definitions/Parking"
      responses:
        201:
          description: "Created"
          schema:
            $ref: "#/definitions/ParkingId"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"
  /parkings/{ParkingId}:
    get:
      tags:
      - "Parking"    
      summary: "Retrieve parking"
      operationId: "retrieveParking"
      produces:
      - "application/json"
      parameters: 
      - name: "ParkingId"
        in: "path"
        type: "string"
        required: true
      responses:
        200:
          description: "OK"
          schema:
            $ref: "#/definitions/Parking"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        404:
          description: "Not Found"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"
    delete:
      tags:
      - "Parking"    
      summary: "Stop parking"
      operationId: "stopParking"
      produces:
      - "application/json"
      parameters: 
      - name: "ParkingId"
        in: "path"
        type: "string"
        required: true
      responses:
        200:
          description: "OK"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        404:
          description: "Not Found"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"
  /charges:
    post:
      tags:
      - "Charge"
      summary: "Charge parking fee"
      operationId: "chargeParkingFee"
      consumes:
      - "application/json"
      produces:
      - "application/json"
      parameters: 
      - in: "body"
        name: "body"
        description: "Charge object"
        required: true
        schema:
          $ref: "#/definitions/Charge"
      responses:
        201:
          description: "Created"
          schema:
            $ref: "#/definitions/ChargeId"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"
  /charges/calculate:
    post:
      tags:
      - "Charge"
      summary: "Calculate parking fee based on current rates, parking time and length"
      operationId: "calculateParkingFee"
      produces:
      - "application/json"
      parameters:
      - name: "ParkingId"
        in: "query"
        required: true
        type: "string"
      responses:
        201:
          description: "Created"
          schema:
            $ref: "#/definitions/ChargeAmount"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"
  /rates:
    put:
      tags:
      - "Rate"
      summary: "Set parking rate"
      operationId: "updateRate"
      consumes:
      - "application/json"
      parameters: 
      - in: "body"
        name: "body"
        description: "Rate object"
        required: true
        schema:
          $ref: "#/definitions/Rate"
      responses:
        200:
          description: "OK"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"
    get:
      tags:
      - "Rate"
      summary: "Get parking rate"
      operationId: "retrieveRate"
      responses:
        200:
          description: "OK"
          schema:
            $ref: "#/definitions/Rate"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"
  /payments:
    post:
      tags:
      - "Payment"
      summary: "Top up account with registered payment"
      operationId: "registerPayment"
      consumes:
      - "application/json"
      produces:
      - "application/json"
      parameters: 
      - in: "body"
        name: "body"
        description: "Charge object"
        required: true
        schema:
          $ref: "#/definitions/Payment"
      responses:
        201:
          description: "Created"
          schema:
            $ref: "#/definitions/PaymentId"
        400:
          description: "Bad Request"
          schema:
            $ref: "#/definitions/Fault"
        500:
          description: "Internal Server Error"
          schema:
            $ref: "#/definitions/Fault"

definitions:
  Fault:
    type: "object"
    properties:
      Code:
        type: "string"
        description: "fault code"
      Message:
        type: "string"
        description: "fault message"
      Details:
        type: "string"
        description: "fault details"
  IdReadWrite:
    type: "string"
    description: "common identificator"
    readOnly: false
  IdReadOnly:
    type: "string"
    description: "common identificator"
    readOnly: true
  PaymentId:
    type: "object"
    description: "identification of payment object"
    properties:
      PaymentId:
        $ref: "#/definitions/IdReadWrite"
  AccountId:
    type: "object"
    description: "identification of account object"
    properties:
      AccountId:
        $ref: "#/definitions/IdReadWrite"
  ChargeId:
    type: "object"
    description: "identification of charge object"
    properties:
      ChargeId:
        $ref: "#/definitions/IdReadWrite"
  ParkingId:
    type: "object"
    description: "identification of parking object"
    properties:
      ParkingId:
        $ref: "#/definitions/IdReadWrite"
  Client:
    type: "object"
    description: "details of clients identification information"
    required: 
      - "FirstName"
      - "LastName"
      - "Pesel"
    properties:
      FirstName:
        type: "string"
        description: "clients first name"
        example: "Jan"
      LastName:
        type: "string"
        description: "clients last name"
        example: "Kowalski"
      Pesel:
        type: "string"
        description: "clients pesel identification number"
        example: "80112200777"
  Vehicle:
    type: "object"
    description: "details of clients vehicle"
    required: 
      - "RegistrationNumber"
      - "VinNumber"
      - "Brand"
      - "Model"
      - "ProductionDate"
    properties:
      RegistrationNumber:
        type: "string"
        description: "clients vehicle registration number"
        example: "WW12345"
      VinNumber:
        type: "string"
        description: "clients vehicle vin number"
        example: "JTDZN3EU5FJ016414"
      Brand:
        type: "string"
        description: "clients vehicle brand name"
        example: "Opel"
      Model:
        type: "string"
        description: "clients vehicle brand model name"
        example: "Corsa"
      ProductionDate:
        type: "string"
        format: "date"
        description: "clients vehicle production date"
        example: "2018-03-15"
  Account:
    type: "object"
    description: "information about clients account"
    allOf:
      - $ref: "#/definitions/Vehicle"
      - $ref: "#/definitions/Client"
      - properties:
          AccountId:
            $ref: "#/definitions/IdReadOnly"
          AccountAmount:
            type: "number"
            format: "double"
            description: "amount od funds on customers account"
            readOnly: true
            example: "97,50"
  Rate:
    type: "object"
    description: "information about parkingrate per minute"
    required: 
      - "RateAmount"
    properties:
      RateAmount:
        type: "number"
        format: "decimal"
        description: "parking rate amount per minute"
        example: "2,50"
  Payment:
    type: "object"
    description: "information about topping up the account"
    required: 
      - "AccountId"
      - "PaymentAmount"
    allOf: 
    - $ref: "#/definitions/AccountId"
    - properties:
        PaymentId:
          $ref: "#/definitions/IdReadOnly"
        PaymentAmount:
          type: "number"
          format: "double"
          description: "top up amount"
          example: "50,00"
  ChargeAmount:
    type: "object"
    properties:
      ChargeAmount:
        type: "number"
        format: "double"
        description: "parking charge amount"
  Charge:
    type: "object"
    description: "information about amount charged for parking"
    required: 
      - "ParkingId"
    allOf: 
    - $ref: "#/definitions/ParkingId"
    - $ref: "#/definitions/ChargeAmount"
    - properties:
        ChargeId:
          $ref: "#/definitions/IdReadOnly"
  Parking:
    type: "object"
    description: "information about parking activity"
    required: 
      - "AccountId"
      - "ParkingType"
      - "ParkingStart"
    allOf: 
    - $ref: "#/definitions/AccountId"
    - properties:
        ParkingId:
          $ref: "#/definitions/IdReadOnly"
        ParkingType:
          type: "string"
          enum: [DEADLINE, PERIOD]
          description: "DEADLINE is parking until specific hour, PERIOD is parking for specific time"
          example: "DEADLINE"
        ParkingStatus:
          type: "string"
          enum: [ACTIVE, COMPLETED, ENDED]
          description: "ACTIVE is current parking, COMPLETED is after parking ends, ENDED is before parking ends"
          example: "ACTIVE"
          readOnly: true
        ParkingStart:
          type: "string"
          format: "date-time"
          description: "parking starting hour"
          example: "2019-02-14T17:00:00"
        ParkingEnd:
          type: "string"
          format: "date-time"
          description: "parking ending hour"
          example: "2019-02-14T19:00:00"
        ParkingPeriod:
          type: "number"
          format: "double"
          description: "parking period, time between parking start and parking end"
  Parkings:
    type: "array"
    items:
      $ref: "#/definitions/Parking"
  Charges:
    type: "array"
    items:
      $ref: "#/definitions/Charge"
  Payments:
    type: "array"
    items:
      $ref: "#/definitions/Payment"
  Rates:
    type: "array"
    items:
      $ref: "#/definitions/Rate"
  Accounts:
    type: "array"
    items:
      $ref: "#/definitions/Account"
