swagger: '2.0'
info:
  description: This is API definition for eParkingRX application
  version: 1.0.0
  title: eParkingRX API
  termsOfService: 'http://swagger.io/terms/'
  contact:
    email: kuba.szklarski@gmail.com
  license:
    name: Apache 2.0
    url: 'http://www.apache.org/licenses/LICENSE-2.0.html'
host: 'eparkingrx.swagger.io:8080'
basePath: /v1
schemes:
  - http
tags:
  - name: RegisterAccount
    description: Account registration
  - name: RetrieveAccount
    description: Account retrieval
  - name: DisableAccount
    description: Account deactivation
  - name: ValidateAccount
    description: Account validation
  - name: RegisterPayment
    description: Payment registration
  - name: CheckBalance
    description: Payment balance check
  - name: ChargeFee
    description: Parking fee charge
  - name: SetRate
    description: Update parking rates
  - name: StartParking
    description: Parking start
  - name: EndParking
    description: Parking end
paths:
  /accounts:
    post:
      tags:
        - RegisterAccount
      summary: Account registration
      operationId: RegisterAccount
      consumes:
        - application/json
        - application/xml
      produces:
        - application/json
        - application/xml
      parameters:
        - in: body
          name: RegisterAccount
          description: Account registration input
          required: true
          schema:
            $ref: '#/definitions/RegisterAccount'
      responses:
        '201':
          description: Account registered
          schema:
            $ref: '#/definitions/RegisterAccountResponse'
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
  '/accounts/{AccountId}':
    get:
      tags:
        - RetrieveAccount
      summary: Account retrieval
      operationId: RetrieveAccount
      produces:
        - application/json
        - application/xml
      parameters:
        - name: AccountId
          in: path
          type: string
          description: Account identification
          required: true
      responses:
        '200':
          description: OK
          schema:
            $ref: '#/definitions/RetrieveAccountResponse'
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '404':
          description: Account not found
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
    delete:
      tags:
        - DisableAccount
      summary: Account deactivation
      operationId: DisableAccount
      produces:
        - application/json
        - application/xml
      parameters:
        - name: AccountId
          in: path
          type: string
          description: Account identification
          required: true
      responses:
        '200':
          description: OK
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
  /accounts/validate:
    post:
      tags:
        - ValidateAccount
      summary: Account validation
      operationId: ValidateAccount
      consumes:
        - application/json
        - application/xml
      produces:
        - application/json
        - application/xml
      parameters:
        - in: body
          name: ValidateAccount
          description: Account validation input
          required: true
          schema:
            $ref: '#/definitions/ValidateAccount'
      responses:
        '200':
          description: Account validated
          schema:
            $ref: '#/definitions/ValidateAccountResponse'
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
  /payments:
    post:
      tags:
        - RegisterPayment
      summary: Payment registration
      operationId: RegisterPayment
      consumes:
        - application/json
        - application/xml
      produces:
        - application/json
        - application/xml
      parameters:
        - in: body
          name: RegisterPayment
          description: Payment registration input
          required: true
          schema:
            $ref: '#/definitions/RegisterPayment'
      responses:
        '201':
          description: Payment registered
          schema:
            $ref: '#/definitions/RegisterPaymentResponse'
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
  '/payments/{AccountId}':
    get:
      tags:
        - CheckBalance
      summary: Payment balance check
      operationId: CheckBalance
      produces:
        - application/json
        - application/xml
      parameters:
        - name: AccountId
          in: path
          type: string
          description: Account identification
          required: true
      responses:
        '200':
          description: OK
          schema:
            $ref: '#/definitions/CheckBalanceResponse'
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '404':
          description: Payment not found
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
  /fees:
    post:
      tags:
        - ChargeFee
      summary: Parking fee charge
      operationId: ChargeFee
      consumes:
        - application/json
        - application/xml
      produces:
        - application/json
        - application/xml
      parameters:
        - in: body
          name: ChargeFee
          description: Charge fee
          required: true
          schema:
            $ref: '#/definitions/ChargeFee'
      responses:
        '201':
          description: Fee charged
          schema:
            $ref: '#/definitions/ChargeFeeResponse'
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
  /rates:
    put:
      tags:
        - SetRate
      summary: Update parking rates
      operationId: SetRate
      consumes:
        - application/json
        - application/xml
      produces:
        - application/json
        - application/xml
      parameters:
        - in: body
          name: SetRate
          description: Parking rate input
          required: true
          schema:
            $ref: '#/definitions/SetRate'
      responses:
        '200':
          description: Parking rate updated
          schema:
            $ref: '#/definitions/SetRateResponse'
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
  /parking:
    post:
      tags:
        - StartParking
      summary: Parking start
      operationId: StartParking
      consumes:
        - application/json
        - application/xml
      produces:
        - application/json
        - application/xml
      parameters:
        - in: body
          name: StartParking
          description: Start parking input
          required: true
          schema:
            $ref: '#/definitions/StartParking'
      responses:
        '201':
          description: Parking started
          schema:
            $ref: '#/definitions/StartParkingResponse'
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
  '/parking/{ParkingId}':
    delete:
      tags:
        - EndParking
      summary: Parking end
      operationId: EndParking
      consumes:
        - application/json
        - application/xml
      produces:
        - application/json
        - application/xml
      parameters:
        - name: ParkingId
          in: path
          type: string
          description: End parking input
          required: true
      responses:
        '200':
          description: Parking ended
          schema:
            $ref: '#/definitions/EndParkingResponse'
        '400':
          description: Invalid input
          schema:
            $ref: '#/definitions/Fault'
        '500':
          description: Internal system error
          schema:
            $ref: '#/definitions/Fault'
        '502':
          description: External system fault
          schema:
            $ref: '#/definitions/Fault'
definitions:
  RegisterAccount:
    type: object
    description: information about clients account
    properties:
      Amount:
        $ref: '#/definitions/Amount'
      Client:
        $ref: '#/definitions/Client'
      Vehicle:
        $ref: '#/definitions/Vehicle'
  RegisterAccountResponse:
    type: object
    description: information about clients account
    properties:
      AccountId:
        $ref: '#/definitions/AccountId'
  RetrieveAccountResponse:
    type: object
    description: information about clients account
    properties:
      Account:
        $ref: '#/definitions/Account'
  ValidateAccount:
    type: object
    description: information required to perform account validation
    properties:
      Amount:
        $ref: '#/definitions/Amount'
      Client:
        $ref: '#/definitions/Client'
      Vehicle:
        $ref: '#/definitions/Vehicle'
  ValidateAccountResponse:
    type: object
    description: account validation result
    properties:
      ValidationResult:
        $ref: '#/definitions/ValidationResult'
  RegisterPayment:
    type: object
    description: information about topping up the account
    properties:
      AccountId:
        $ref: '#/definitions/AccountId'
      Amount:
        $ref: '#/definitions/Amount'
  RegisterPaymentResponse:
    type: object
    description: information about clients account
    properties:
      Payment:
        $ref: '#/definitions/Payment'
  CheckBalanceResponse:
    type: object
    description: information about topping up the account
    properties:
      Amount:
        $ref: '#/definitions/Amount'
  ChargeFee:
    type: object
    description: information about amount charged for parking
    properties:
      Parking:
        $ref: '#/definitions/Parking'
  ChargeFeeResponse:
    type: object
    description: information about amount charged for parking
    properties:
      Amount:
        $ref: '#/definitions/Amount'
  SetRate:
    type: object
    description: information about parking rate per minute
    properties:
      Amount:
        $ref: '#/definitions/Amount'
  SetRateResponse:
    type: object
    description: information about clients account
    properties:
      Rate:
        $ref: '#/definitions/Rate'
  StartParking:
    type: object
    description: information about amount charged for parking
    properties:
      AccountId:
        $ref: '#/definitions/AccountId'
      ParkingType:
        $ref: '#/definitions/ParkingType'
      ParkingStatus:
        $ref: '#/definitions/ParkingStatus'
      ParkingStartTime:
        $ref: '#/definitions/ParkingStartTime'
      ParkingEndTime:
        $ref: '#/definitions/ParkingEndTime'
      ParkingPeriod:
        $ref: '#/definitions/ParkingPeriod'
  StartParkingResponse:
    type: object
    description: information about amount charged for parking
    properties:
      ParkingId:
        $ref: '#/definitions/ParkingId'
  EndParkingResponse:
    type: object
    description: information about amount charged for parking
    properties:
      Amount:
        $ref: '#/definitions/Amount'
  AccountId:
    type: string
    description: identification of account object
  PaymentId:
    type: string
    description: identification of payment object
  ParkingId:
    type: string
    description: identification of parking object
  Amount:
    type: number
    format: double
    description: universal amount
    example: '10.00'
  Account:
    type: object
    description: information about clients account
    properties:
      AccountId:
        $ref: '#/definitions/AccountId'
      Status:
        type: string
        description: Account status
        enum:
          - ENABLED
          - DISABLED
        example: ENABLED
      Amount:
        $ref: '#/definitions/Amount'
      Client:
        $ref: '#/definitions/Client'
      Vehicle:
        $ref: '#/definitions/Vehicle'
  Client:
    type: object
    description: details of clients identification information
    properties:
      FirstName:
        type: string
        description: clients first name
        example: Jan
      LastName:
        type: string
        description: clients last name
        example: Kowalski
      Pesel:
        type: string
        description: clients pesel identification number
        example: '80112200777'
      Status:
        type: string
        description: clients status
        enum:
          - NEW
          - ACTIVE
        example: NEW
  Vehicle:
    type: object
    description: details of clients vehicle
    properties:
      RegistrationNumber:
        type: string
        description: clients vehicle registration number
        example: WW12345
      VinNumber:
        type: string
        description: clients vehicle vin number
        example: JTDZN3EU5FJ016414
      Brand:
        type: string
        description: clients vehicle brand name
        example: Opel
      Model:
        type: string
        description: clients vehicle brand model name
        example: Corsa
      ProductionDate:
        type: string
        format: date
        description: clients vehicle production date
        example: '2018-03-15'
  Parking:
    type: object
    description: information about parking activity
    properties:
      ParkingId:
        $ref: '#/definitions/ParkingId'
      AccountId:
        $ref: '#/definitions/AccountId'
      ParkingType:
        $ref: '#/definitions/ParkingType'
      ParkingStatus:
        $ref: '#/definitions/ParkingStatus'
      ParkingStartTime:
        $ref: '#/definitions/ParkingStartTime'
      ParkingEndTime:
        $ref: '#/definitions/ParkingEndTime'
      ParkingPeriod:
        $ref: '#/definitions/ParkingPeriod'
  ParkingType:
    type: string
    enum:
      - DEADLINE
      - PERIOD
    description: 'DEADLINE is parking until specific hour, PERIOD is parking for specific time'
    example: DEADLINE
  ParkingStatus:
    type: string
    enum:
      - ACTIVE
      - COMPLETED
      - ENDED
    description: 'ACTIVE is current parking, COMPLETED is after parking ends, ENDED is before parking ends'
    example: ACTIVE
  ParkingStartTime:
    type: string
    format: date-time
    description: parking starting hour
    example: '2019-02-14T17:00:00'
  ParkingEndTime:
    type: string
    format: date-time
    description: parking ending hour
    example: '2019-02-14T19:00:00'
  ParkingPeriod:
    type: number
    format: double
    description: 'parking period, time in seconds between parking start and parking end'
    example: '600'
  Payment:
    type: object
    description: information about topping up the account
    properties:
      PaymentId:
        $ref: '#/definitions/PaymentId'
      AccountId:
        $ref: '#/definitions/AccountId'
      Amount:
        $ref: '#/definitions/Amount'
  Rate:
    type: object
    description: information about parking rate per minute
    properties:
      RateAmount:
        $ref: '#/definitions/Amount'
  ValidationResult:
    type: object
    description: generic validation result
    properties:
      Result:
        type: string
        description: validation result
        enum:
          - VALID
          - INVALID
      Messages:
        type: array
        description: list of validation messages
        items:
          type: string
          description: validation message
  Fault:
    type: object
    description: generic fault
    properties:
      Type:
        type: string
        description: type of fault
        enum:
          - VALIDATION
          - TECHNICAL
          - BUSINESS
      Code:
        type: string
        description: fault code
      Message:
        type: string
        description: fault message
      Details:
        type: string
        description: fault details
